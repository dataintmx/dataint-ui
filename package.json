{
  "name": "@dataint/ui",
  "version": "0.1.0",
  "description": "A lightweight CSS-based design system for DataInt applications.",
  "license": "MIT",
  "author": "DataInt",
  "repository": {
    "type": "git",
    "url": "https://github.com/dataintmx/dataint-ui.git"
  },
  "style": "dist/styles.css",
  "exports": {
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "postcss src/index.css -o dist/styles.css",
    "prepublishOnly": "npm run build",
    "dev:playground": "npx serve playground",
    "build:playground": "npx @tailwindcss/cli -i playground/css/input.css -o playground/css/output.css"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^4.0.0"
  }
}
