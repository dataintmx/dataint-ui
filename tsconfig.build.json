{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "rootDir": "./src",
        "outDir": "./dist",

        "declaration": true,
        "declarationMap": true,

        "module": "ESNext",
        "moduleResolution": "Bundler"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules", "playground"]
}
